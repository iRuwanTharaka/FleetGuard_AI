# Server
PORT=3001
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fleetguard_db
DB_USER=bethmij
DB_PASSWORD=postgres

# JWT
JWT_SECRET=fleetguard_super_secret_key_minimum_32_chars_long
JWT_EXPIRES_IN=8h

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Email (Gmail App Password — not your normal Gmail password)
EMAIL_USER=fleetguardai@gmail.com
EMAIL_PASS=your_gmail_app_password

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# AI Microservice (Sprint 3 — leave as-is for now)
AI_SERVICE_URL=http://localhost:5000
AI_TIMEOUT=30000

# Frontend URL (for CORS whitelist)
FRONTEND_URL=http://localhost:5173
